# ── Web app ──────────────────────────────────────────────────────────────────
# Which match feed the app runs on. Default (unset) = sim → fully demoable with
# NO token. Set to "live" only once TXLINE_API_KEY is provisioned.
NEXT_PUBLIC_FEED=sim
# Sim replay speed multiplier (1 = ~5-min match). Bump for quick local testing.
# NEXT_PUBLIC_SIM_SPEED=1
# Live feed only: fixture id to surface in the lobby (schedule API is a TODO).
# NEXT_PUBLIC_TXLINE_FIXTURE_ID=

# ── Wallet auth + paid rooms (DEVNET ONLY — demo money, never mainnet) ──────
# REQUIRED for sign-in: Privy app id (email login → embedded Solana wallet).
# Create a free app at https://dashboard.privy.io, enable Email + Solana
# embedded wallets, then paste the App ID here.
NEXT_PUBLIC_PRIVY_APP_ID=
# Devnet RPC (default https://api.devnet.solana.com). Mainnet URLs are refused.
# NEXT_PUBLIC_SOLANA_RPC=
# Deployed `eleven` program + rake treasury (defaults = the live devnet deploy).
# NEXT_PUBLIC_ELEVEN_PROGRAM_ID=2DoTb77aro9SoArLPQMucnCxoTDnvZvZskYtYhSdywRm
# NEXT_PUBLIC_TREASURY=5ufkUNHzdRhGkW2gbiEgrpJfmzvwWoF1aPo4hbZ63mmd
# PRIMARY demo-funding faucet: a pre-funded DEVNET keypair (JSON secret-key
# array) that tops every account up to the guaranteed $50.00 demo balance.
# The public devnet airdrop rate-limits hard, so set this for reliability:
#   solana-keygen new -o ~/.config/solana/eleven-demo-faucet.json
#   solana transfer <its pubkey> 1.5 -u devnet --allow-unfunded-recipient
#   DEMO_FAUCET_SECRET=<contents of the json file>
# NEVER a mainnet key, NEVER committed. Without it the app falls back to the
# rate-limited public airdrop.
# DEMO_FAUCET_SECRET=

# ── TxLINE (server-side; live feed + probe) ─────────────────────────────────
# TxLINE API token (X-Api-Token). Issued by POST /api/token/activate after an
# on-chain `subscribe` tx. Free World Cup tier = Service Level 1 or 12.
# Used by the /api/txline/stream proxy and scripts/txline-probe.ts.
TXLINE_API_KEY=

# Optional overrides
# The FREE World Cup tier registers on the DEVNET backend, so point everything at dev:
# TXLINE_ORIGIN=https://txline-dev.txodds.com     # prod is https://txline.txodds.com
# TXLINE_COMPETITION_ID=72                         # 72 = World Cup (fixtures + stream)
# TXLINE_PROBE_TIMEOUT_MS=120000
# Live lobby fixtures window (used by /api/txline/fixtures → /api/fixtures/snapshot):
# TXLINE_FIXTURES_START_EPOCHDAY=20639             # first epoch day to pull
# TXLINE_FIXTURES_DAYS=6                            # number of days to union
