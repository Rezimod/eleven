    {
      "name": "LivePick",
      "docs": [
        "Dedup guard for a LIVE pick revealed against a market's Merkle root — its mere",
        "existence proves this (owner, market) already scored, so a pick can't be",
        "revealed twice. Created by `reveal_live_pick`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "room",
            "type": "pubkey"
          },
